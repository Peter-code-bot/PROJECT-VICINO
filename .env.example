# Supabase
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role solo para server-side (NUNCA exponer al cliente). Necesario para
# /api/reports POST handler (insert con elevación de privilegios protegida por
# rate-limit + auth check).
SUPABASE_SERVICE_ROLE_KEY=

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Moderación — Webhook de Database (configurado en Supabase Dashboard)
# Generar con: openssl rand -hex 32
SUPABASE_WEBHOOK_SECRET=

# Moderación — Email vía Resend (https://resend.com)
# Crear cuenta + API key + verificar dominio vicinomarket.com (SPF/DKIM)
RESEND_API_KEY=
ADMIN_EMAIL=admin@vicinomarket.com
RESEND_FROM_NORMAL=VICINO Moderation <moderation@vicinomarket.com>
RESEND_FROM_URGENT=VICINO Alerts <alerts@vicinomarket.com>
